<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Contact Us - BiteBazar</title>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    body {
      background-color: #f9f9f9;
    }

    header {
      background-color: #2c2c2c;
      color: white;
      padding: 15px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    nav ul {
      list-style: none;
      display: flex;
    }

    nav ul li {
      margin: 0 10px;
    }

    nav ul li a {
      text-decoration: none;
      color: white;
      font-weight: bold;
    }

    nav ul li a:hover {
      text-decoration: underline;
    }

    section {
      padding: 30px;
      text-align: center;
    }

    h2 {
      margin-bottom: 20px;
      color: #fff5f5;
    }

    /* Contact Info */
    .contact-info {
      background: #fff5f5;
      padding: 15px;
      border-radius: 10px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
      margin-bottom: 20px;
    }

    .contact-info p {
      font-size: 18px;
      color: #333;
      margin: 5px 0;
    }

    .contact-info strong {
      color: #2c2c2c;
    }

    /* FORM */
    form {
      max-width: 400px;
      margin: auto;
      display: flex;
      flex-direction: column;
    }

    .input-box {
      position: relative;
      margin: 10px 0;
    }

    .input-box input,
    .input-box textarea {
      width: 100%;
      padding: 12px;
      font-size: 16px;
      border: 1px solid #ccc;
      border-radius: 5px;
      outline: none;
      background: transparent;
    }

    .input-box label {
      position: absolute;
      left: 12px;
      top: 12px;
      color: gray;
      transition: 0.3s ease;
      pointer-events: none;
      background: #f9f9f9;
      padding: 0 5px;
    }

    /* Floating Effect */
    .input-box input:focus + label,
    .input-box input:not(:placeholder-shown) + label,
    .input-box textarea:focus + label,
    .input-box textarea:not(:placeholder-shown) + label {
      top: -10px;
      font-size: 12px;
      color: #2c2c2c;
    }

    button {
      padding: 10px;
      background-color: #2c2c2c;
      color: white;
      border: none;
      border-radius: 5px;
      cursor: pointer;
      font-size: 16px;
    }

    button:hover {
      background-color: #444;
    }

    .success-message {
      margin-top: 10px;
      font-weight: bold;
    }

    footer {
      background-color: #333;
      color: white;
      text-align: center;
      padding: 10px;
      margin-top: 20px;
    }
  </style>
</head>

<body>

<header>
  <div class="logo">
    <h2>BiteBazar</h2>
  </div>
  <nav>
    <ul>
      <li><a href="index.html">Home</a></li>
      <li><a href="menu.html">Menu</a></li>
      <li><a href="orders.html">Orders</a></li>
      <li><a href="contact.html">Contact</a></li>
    </ul>
  </nav>
</header>

<section>
  <h2>Contact Us</h2>

  <div class="contact-info">
    <p><strong>📞 Phone:</strong> +92 330 7829796</p>
    <p><strong>☎️ PTCL:</strong> 0604 182876</p>
    <p><strong>📧 Email:</strong> bitebazar7@gmail.com</p>
  </div>

  <form id="contactForm">

    <div class="input-box">
      <input type="text" id="name" required placeholder=" ">
      <label>Your Name</label>
    </div>

    <div class="input-box">
      <input type="email" id="email" required placeholder=" ">
      <label>Your Email</label>
    </div>

    <div class="input-box">
      <textarea id="message" rows="5" required placeholder=" "></textarea>
      <label>Your Message</label>
    </div>

    <button type="submit">Send Message</button>
    <div class="success-message" id="contactMsg"></div>

  </form>
</section>

<footer>
  <p>&copy; 2025 BiteBazar. All rights reserved.</p>
</footer>

<script>
  document.getElementById("contactForm").addEventListener("submit", async function (e) {
    e.preventDefault();

    const name = document.getElementById("name").value.trim();
    const email = document.getElementById("email").value.trim();
    const message = document.getElementById("message").value.trim();
    const contactMsg = document.getElementById("contactMsg");

    if (!validateEmail(email)) {
      contactMsg.style.color = "red";
      contactMsg.textContent = "Invalid email address.";
      return;
    }

    const response = await fetch("https://formspree.io/f/xanerkgj", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ name, email, message }),
    });

    if (response.ok) {
      contactMsg.style.color = "green";
      contactMsg.textContent = "Message sent successfully!";
      document.getElementById("contactForm").reset();
    } else {
      contactMsg.style.color = "red";
      contactMsg.textContent = "Failed to send message. Try again later.";
    }
  });

  function validateEmail(email) {
    const re = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    return re.test(email);
  }
</script>

</body>
</html>
